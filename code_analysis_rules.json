{
  "log_level": "all",
  "max_lines_per_file": {
    "enabled": true,
    "warning": 300,
    "error": 500,
    "exceptions": [
      {
        "file": "tests/test_contacts_service.py",
        "warning": 350,
        "error": 500,
        "reason": "Test suite for contacts service"
      }
    ]
  },
  "pmd_duplicates": {
    "enabled": true,
    "minimum_tokens": 100,
    "exclude_patterns": {
      "python": [
        "__pycache__/**",
        "*.pyc",
        "venv/**",
        ".venv/**",
        "*venv/**",
        "env/**",
        ".git/**"
      ]
    }
  },
  "pmd_similar_code": {
    "enabled": false,
    "minimum_tokens": 100,
    "ignore_identifiers": true,
    "ignore_literals": true,
    "ignore_annotations": false,
    "exclude_patterns": {
      "python": [
        "__pycache__/**",
        "*.pyc",
        "venv/**",
        ".venv/**",
        "*venv/**",
        "env/**",
        ".git/**"
      ]
    }
  },
  "ruff_analyze": {
    "enabled": true,
    "select": ["E", "F", "W"],
    "ignore": [],
    "exclude_patterns": ["venv/**", "__pycache__/**", ".git/**"]
  }
}
